{
  "title": "Data Tier: Postgres & Redis",
  "uid": "eks-v2-data-tier",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["eks-v2", "data-tier"],
  "timezone": "utc",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Postgres Scrape Target Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{namespace=\"data\", pod=~\"postgres-.*\"}", "legendFormat": "{{pod}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "CNPG Collector Up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "cnpg_collector_up{namespace=\"data\"}", "legendFormat": "{{pod}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Postgres PVC Usage %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "100 * kubelet_volume_stats_used_bytes{namespace=\"data\", persistentvolumeclaim=~\"postgres.*\"} / kubelet_volume_stats_capacity_bytes{namespace=\"data\", persistentvolumeclaim=~\"postgres.*\"}",
          "legendFormat": "{{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100, "min": 0 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Redis Memory Working Set",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"data\", pod=~\"redis-.*\", container=\"redis\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}

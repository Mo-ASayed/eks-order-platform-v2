{
  "title": "Event Bus & Ingress",
  "uid": "eks-v2-event-bus-ingress",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["eks-v2", "event-bus", "ingress"],
  "timezone": "utc",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "SQS Main Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "aws_sqs_approximate_number_of_messages_visible_maximum{name=\"sqs-main\"}", "legendFormat": "main queue", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 2,
      "title": "SQS Dead-Letter Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "aws_sqs_approximate_number_of_messages_visible_maximum{name=\"sqs-dlq\"}", "legendFormat": "dlq", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "api-gateway Request Rate by Status Code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(traefik_service_requests_total{service=~\".*api-gateway.*\"}[5m])) by (code)", "legendFormat": "{{code}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 4,
      "title": "api-gateway 5xx Rate %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(traefik_service_requests_total{service=~\".*api-gateway.*\", code=~\"5..\"}[5m])) / sum(rate(traefik_service_requests_total{service=~\".*api-gateway.*\"}[5m]))",
          "legendFormat": "5xx %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    }
  ]
}
